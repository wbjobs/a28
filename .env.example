# S3 Configuration
S3_BUCKET_NAME=video-understanding-models
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Model paths (will be downloaded from S3 if not cached)
MODEL_CACHE_DIR=./python/models_cache
CLASSIFICATION_MODEL=classification_model.onnx
DETECTION_MODEL=yolov8n.onnx
WHISPER_MODEL=whisper-base

# Server configuration
NODE_PORT=3000
PYTHON_PORT=5000
